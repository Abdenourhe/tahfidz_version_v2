# ─── Base de données PostgreSQL ───────────────────────────────────────────────
# En local : installer PostgreSQL ou utiliser Docker (voir docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tahfidz"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
AUTH_SECRET="CHANGEME_openssl_rand_base64_32"
AUTH_URL="http://localhost:3000"

# ─── Domaine racine ───────────────────────────────────────────────────────────
# En local : localhost:3000 (pas de sous-domaines réels, voir note ci-dessous)
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
# En local : installer Redis ou utiliser Docker
REDIS_URL="redis://localhost:6379"

# ─── API interne (middleware → résolution schoolId) ───────────────────────────
INTERNAL_API_SECRET="CHANGEME_secret_interne"

# ─── Production uniquement ────────────────────────────────────────────────────
# NEXT_PUBLIC_ROOT_DOMAIN="tahfidz"
# DATABASE_URL="postgresql://..."   # Railway ou Supabase
# REDIS_URL="rediss://..."          # Upstash Redis
