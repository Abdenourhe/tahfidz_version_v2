# ============================================
# EXEMPLE DE CONFIGURATION — TAHFIDZ
# Copier ce fichier en .env pour le dev local
# SUR VERCEL: ajouter ces variables dans Settings → Environment Variables
# ============================================

# --- Base de donnees (Neon/PostgreSQL) ---
POSTGRES_URL="postgresql://user:password@host/db?sslmode=require"
POSTGRES_PRISMA_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host/db?sslmode=require"

# --- Authentification (NextAuth v5) ---
NEXTAUTH_URL="https://votre-app.vercel.app"
NEXTAUTH_SECRET="votre-secret-nextauth-min-32-caracteres-ici"
AUTH_TRUST_HOST="true"

# --- Email (SendGrid API — obligatoire pour les emails) ---
# 1. SendGrid → Settings → API Keys → Create API Key (Full Access ou Mail Send)
# 2. Copier la cle (commence par SG.)
SENDGRID_API_KEY="SG.VOTRE_CLE_API_ICI"

# 3. SendGrid → Settings → Sender Authentication → Single Sender Verification
# 4. Mettre ici L'EMAIL VERIFIE exactement (pas noreply@... si non verifie)
SMTP_FROM="TAHFIDZ <ton-email-verifie@gmail.com>"

# --- URL publique de l'app ---
NEXT_PUBLIC_APP_URL="https://votre-app.vercel.app"

# --- Stockage Cloudflare R2 (PDFs et médias) ---
# 1. Cloudflare Dashboard → R2 Object Storage → Create bucket (accès privé)
# 2. R2 → Manage R2 API Tokens → Create API Token → permissions Admin Read & Write
# 3. Récupérer Account ID, S3 API endpoint, Access Key ID et Secret Access Key
R2_ACCOUNT_ID="votre-account-id"
R2_BUCKET_NAME="votre-bucket"
R2_ENDPOINT="https://votre-account-id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="votre-access-key-id"
R2_SECRET_ACCESS_KEY="votre-secret-access-key"

# --- Notifications push Web (VAPID) ---
# 1. Générer une paire de clés : npx web-push generate-vapid-keys
# 2. Renseigner la clé publique côté client et la clé privée côté serveur
# 3. Le subject doit être une URL mailto: ou https: de votre organisation
VAPID_PUBLIC_KEY="votre-cle-publique-vapid"
VAPID_PRIVATE_KEY="votre-cle-privee-vapid"
VAPID_SUBJECT="mailto:abdenour.hellas@uqat.ca"

# --- BigBlueButton (Halaqa Online) ---
# 1. Installer un serveur BBB (https://docs.bigbluebutton.org/) ou utiliser un hébergeur
# 2. Récupérer l'URL de l'API (ex: https://bbb.votre-ecole.com/bigbluebutton)
# 3. Récupérer le Shared Secret dans /var/lib/tomcat10/webapps/bigbluebutton/WEB-INF/classes/bigbluebutton.properties
BBB_SERVER_URL="https://votre-serveur-bbb.com/bigbluebutton"
BBB_SECRET="votre-shared-secret-bbb"

# --- Sécurité QR code (cartes étudiants) ---
# Clé secrète utilisée pour signer les QR codes de présence.
# Générer une valeur aléatoire d'au moins 32 caractères :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_HMAC_SECRET="votre-secret-hmac-qr-min-32-caracteres-ici"
