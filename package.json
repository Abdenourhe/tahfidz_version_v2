{
  "name": "tahfidz-saas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:seed": "prisma db seed --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:reset": "prisma migrate reset --force --schema=./prisma/schema.prisma && prisma db seed --schema=./prisma/schema.prisma",
    "workers:start": "tsx --tsconfig tsconfig.json jobs/workers.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.16.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "ioredis": "^5.4.1",
    "lucide-react": "^1.14.0",
    "next": "15.1.0",
    "next-auth": "5.0.0-beta.25",
    "next-intl": "^3.26.3",
    "react": "18.3.1",
    "react-country-flag": "^3.1.0",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.75.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.4",
    "use-debounce": "^10.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^2.1.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "15.1.0",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "vitest-mock-extended": "^2.0.2"
  },
  "prisma": {
    "seed": "tsx --tsconfig tsconfig.json prisma/seed.ts"
  }
}