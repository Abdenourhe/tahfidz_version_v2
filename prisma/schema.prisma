// schema.prisma — TAHFIDZ SaaS
// Architecture multi-tenant : Row-Level Isolation par schoolId

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  SUPERADMIN  // Anthropique / plateforme — accès toutes écoles
  ADMIN       // Directeur d'école
  TEACHER
  PARENT
  STUDENT
}

enum SchoolPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum Gender {
  MALE
  FEMALE
}

enum MemorizationStatus {
  NOT_STARTED
  IN_PROGRESS
  UNDER_REVIEW
  READY_FOR_RECITATION
  PENDING_TEACHER_APPROVAL
  MEMORIZED
  NEEDS_REVISION
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AnnouncementType {
  GENERAL
  EVENT
  ACHIEVEMENT
  URGENT
}

enum BadgeRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum EvaluationDecision {
  APPROVED
  NEEDS_REVISION
  REJECTED
}

// ==================== ÉCOLE (tenant racine) ====================

model School {
  id        String     @id @default(uuid())
  name      String
  nameAr    String?
  slug      String     @unique             // "tahfidz-demo" — identifiant de l'école
  plan      SchoolPlan @default(FREE)
  isActive  Boolean    @default(true)
  settings  Json       @default("{}")
  // Coordonnées de l'école
  address   String?                        // Adresse locale
  city      String?                        // Ville / Wilaya
  country   String?    @default("DZ")      // Code pays ISO
  phone     String?                        // Téléphone de l'admin / école
  logo      String?                        // URL ou chemin vers le logo de l'école
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Toutes les entités appartenant à cette école
  users          User[]
  groups         Group[]
  announcements  Announcement[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  exams          Exam[]
  directMessages DirectMessage[]
  badges         Badge[]
  feedbacks      Feedback[]

  @@index([slug])
  @@map("schools")
}

// ==================== UTILISATEURS ====================

model User {
  id            String    @id @default(uuid())
  schoolId      String                        // tenant
  email         String
  password      String
  fullName      String
  fullNameAr    String?
  role          UserRole
  phone         String?
  gender        Gender?
  avatar        String?
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Profils selon le rôle
  adminProfile   Admin?
  teacherProfile Teacher?
  parentProfile  Parent?
  studentProfile Student?

  // Notifications & sessions
  notifications    Notification[]
  sentMessages     DirectMessage[] @relation("SentMessages")
  receivedMessages DirectMessage[] @relation("ReceivedMessages")
  sessions         Session[]
  auditLogs        AuditLog[]
  announcements    Announcement[]
  feedbacks        Feedback[]

  @@unique([schoolId, email])           // même email autorisé dans 2 écoles
  @@index([schoolId, role])
  @@index([schoolId, email])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Admin {
  id          String @id @default(uuid())
  userId      String @unique
  permissions Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Teacher {
  id             String  @id @default(uuid())
  userId         String  @unique
  bio            String?
  specialization String?
  maxStudents    Int     @default(20)
  isActive       Boolean @default(true)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups      Group[]
  evaluations Evaluation[]
  students    Student[]
  exams       Exam[]

  @@map("teachers")
}

model Parent {
  id     String @id @default(uuid())
  userId String @unique

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  childrenLinks ParentStudentLink[]

  @@map("parents")
}

model Student {
  id             String    @id @default(uuid())
  userId         String    @unique
  studentCode    String    @default(cuid())
  dateOfBirth    DateTime?
  enrollmentDate DateTime  @default(now())
  groupId        String?
  teacherId      String?

  // Progression
  currentSurahId    Int?
  totalStars        Int       @default(0)
  currentStreak     Int       @default(0)
  longestStreak     Int       @default(0)
  lastActivityDate  DateTime?
  status            String    @default("active")

  // Relations
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group                Group?                @relation(fields: [groupId], references: [id])
  teacher              Teacher?              @relation(fields: [teacherId], references: [id])
  parentLinks          ParentStudentLink[]
  memorizationProgress MemorizationProgress[]
  memorizedSurahs      MemorizedSurah[]
  attendances          Attendance[]
  studentBadges        StudentBadge[]
  starsLogs            StarsLog[]
  evaluations          Evaluation[]
  stats                StudentStats?

  @@index([groupId])
  @@index([teacherId])
  @@index([studentCode])
  @@map("students")
}

model ParentStudentLink {
  id         String   @id @default(uuid())
  parentId   String
  studentId  String
  relation   String   // father, mother, guardian
  accessCode String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_student_links")
}

// ==================== GROUPES ====================

model Group {
  id          String   @id @default(uuid())
  schoolId    String                        // tenant
  name        String
  nameAr      String?
  teacherId   String
  level       String   // beginner, intermediate, advanced
  schedule    Json?
  maxCapacity Int      @default(15)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  school        School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher       Teacher             @relation(fields: [teacherId], references: [id])
  students      Student[]
  exams         Exam[]
  announcements GroupAnnouncement[]
  attendances   Attendance[]

  @@index([schoolId])
  @@index([teacherId])
  @@map("groups")
}

// ==================== SOURATES (données globales) ====================

model Surah {
  id              Int    @id
  nameAr          String
  nameFr          String
  nameEn          String
  verseCount      Int
  juzNumber       Int
  revelationType  String  // meccan, medinan
  difficultyLevel Int     @default(3)
  orderInMushaf   Int

  progressRecords  MemorizationProgress[]
  memorizedRecords MemorizedSurah[]

  @@map("surahs")
}

// ==================== MÉMORISATION ====================

model MemorizationProgress {
  id                   String             @id @default(uuid())
  studentId            String
  surahId              Int
  startVerse           Int                @default(1)
  endVerse             Int
  targetDate           DateTime?
  status               MemorizationStatus @default(NOT_STARTED)
  currentVerse         Int                @default(1)
  completionPercentage Float              @default(0)
  startedAt            DateTime           @default(now())
  completedAt          DateTime?
  updatedAt            DateTime           @updatedAt

  student       Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  surah         Surah              @relation(fields: [surahId], references: [id])
  evaluation    Evaluation?
  statusHistory StatusHistory[]

  @@unique([studentId, surahId, startVerse, endVerse])
  @@index([studentId, status])
  @@map("memorization_progress")
}

model StatusHistory {
  id         String             @id @default(uuid())
  progressId String
  oldStatus  MemorizationStatus
  newStatus  MemorizationStatus
  changedBy  String
  changedAt  DateTime           @default(now())
  note       String?

  progress MemorizationProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@map("status_history")
}

model MemorizedSurah {
  id              String   @id @default(uuid())
  studentId       String
  surahId         Int
  progressId      String   @unique
  completionDate  DateTime @default(now())
  versesMemorized Int
  finalScore      Int?
  teacherNotes    String?
  starsEarned     Int      @default(0)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  surah   Surah   @relation(fields: [surahId], references: [id])

  @@map("memorized_surahs")
}

// ==================== ÉVALUATIONS ====================

model Evaluation {
  id                  String             @id @default(uuid())
  progressId          String             @unique
  studentId           String
  teacherId           String
  evaluatedAt         DateTime           @default(now())
  evaluationType      String             // live, recorded, test
  memorizationScore   Int
  tajweedScore        Int
  fluencyScore        Int
  makharijScore       Int?
  tafsirUnderstanding Int?
  finalScore          Int
  teacherNotes        String?            @db.Text
  strengths           String[]
  improvements        String[]
  revisionRequired    Boolean            @default(false)
  decision            EvaluationDecision

  progress MemorizationProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  student  Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher  Teacher               @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([teacherId])
  @@map("evaluations")
}

// ==================== PRÉSENCES ====================

model Attendance {
  id           String           @id @default(uuid())
  studentId    String
  groupId      String?
  date         DateTime
  status       AttendanceStatus
  checkInTime  DateTime?
  checkOutTime DateTime?
  notes        String?
  recordedBy   String
  createdAt    DateTime         @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group   Group?  @relation(fields: [groupId], references: [id])

  @@unique([studentId, date])
  @@index([date])
  @@index([groupId])
  @@map("attendances")
}

// ==================== BADGES & RÉCOMPENSES ====================

model Badge {
  id            String      @id @default(uuid())
  schoolId      String?                     // null = badge global (tous les tenants)
  name          String
  nameAr        String
  description   String
  descriptionAr String
  icon          String
  color         String
  criteriaType  String      // surah_count, streak_days, total_stars, perfect_score, juz_complete, attendance
  criteriaValue Int
  rarity        BadgeRarity @default(COMMON)

  school        School?       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentBadges StudentBadge[]

  @@index([schoolId])
  @@map("badges")
}

model StudentBadge {
  id          String   @id @default(uuid())
  studentId   String
  badgeId     String
  earnedAt    DateTime @default(now())
  earnedValue Int

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  badge   Badge   @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([studentId, badgeId])
  @@map("student_badges")
}

model StarsLog {
  id           String   @id @default(uuid())
  studentId    String
  amount       Int
  balanceAfter Int
  sourceType   String   // memorization, attendance, streak, achievement, bonus, penalty
  sourceId     String?
  reason       String
  awardedBy    String?
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("stars_logs")
}

// ==================== ANNONCES ====================

model Announcement {
  id          String           @id @default(uuid())
  schoolId    String                        // tenant
  title       String
  titleAr     String?
  content     String           @db.Text
  contentAr   String?          @db.Text
  type        AnnouncementType @default(GENERAL)
  targetRoles UserRole[]
  isPinned    Boolean          @default(false)
  isPublished Boolean          @default(true)
  publishedAt DateTime         @default(now())
  expiresAt   DateTime?
  createdBy   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  school       School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  author       User                @relation(fields: [createdBy], references: [id])
  targetGroups GroupAnnouncement[]

  @@index([schoolId, isPublished, publishedAt])
  @@map("announcements")
}

model GroupAnnouncement {
  id             String @id @default(uuid())
  announcementId String
  groupId        String

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([announcementId, groupId])
  @@map("group_announcements")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String    @id @default(uuid())
  schoolId  String                        // tenant
  userId    String
  type      String    // progress_update, evaluation, announcement, reminder, achievement
  title     String
  titleAr   String?
  message   String
  messageAr String?
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, userId, isRead])
  @@map("notifications")
}

// ==================== STATISTIQUES ====================

model StudentStats {
  id                     String    @id @default(uuid())
  studentId              String    @unique
  totalSurahsMemorized   Int       @default(0)
  totalVersesMemorized   Int       @default(0)
  totalEvaluationScore   Int       @default(0)
  evaluationCount        Int       @default(0)
  averageScore           Float     @default(0)
  attendanceRate         Float     @default(0)
  currentStreakStart      DateTime?
  longestStreakStart      DateTime?
  longestStreakEnd        DateTime?
  lastCalculatedAt        DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_stats")
}

// ==================== ERROR LOGS ====================

model ErrorLog {
  id        String   @id @default(uuid())
  message   String
  stack     String?
  severity  String   @default("ERROR") // ERROR, WARNING, CRITICAL, INFO
  source    String   @default("api")    // api, client, system
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([severity])
  @@map("error_logs")
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id         String   @id @default(uuid())
  schoolId   String                        // tenant
  userId     String
  action     String
  entityType String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ==================== BROADCAST ====================

model Broadcast {
  id          String   @id @default(uuid())
  schoolId    String?                       // null = toutes les écoles
  title       String
  message     String   @db.Text
  target      String   @default("all")       // all, active, inactive
  sentBy      String
  sentAt      DateTime @default(now())
  readCount   Int      @default(0)
  totalCount  Int      @default(0)

  @@index([schoolId])
  @@index([sentAt])
  @@map("broadcasts")
}

// ==================== EXAMENS ====================

model Exam {
  id          String   @id @default(uuid())
  schoolId    String                        // tenant
  title       String
  titleAr     String?
  description String?  @db.Text
  groupId     String
  teacherId   String
  examDate    DateTime
  duration    Int      @default(60)
  surahIds    Int[]
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@index([schoolId])
  @@index([groupId])
  @@index([teacherId])
  @@map("exams")
}

// ==================== MESSAGES DIRECTS ====================

model DirectMessage {
  id         String   @id @default(uuid())
  schoolId   String                        // tenant
  fromUserId String
  toUserId   String
  subject    String
  body       String   @db.Text
  isRead     Boolean  @default(false)
  sentAt     DateTime @default(now())

  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fromUser User   @relation("SentMessages",     fields: [fromUserId], references: [id])
  toUser   User   @relation("ReceivedMessages", fields: [toUserId],   references: [id])

  @@index([schoolId, toUserId, isRead])
  @@map("direct_messages")
}

// ==================== DEMANDES D'INSCRIPTION ====================

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model SchoolRequest {
  id               String        @id @default(uuid())
  schoolName       String
  city             String?
  country          String        @default("DZ")
  plan             SchoolPlan    @default(FREE)
  address          String?
  adminEmail       String
  adminPassword    String        // bcrypt hash
  adminName        String
  classCount       Int
  studentsPerClass Int
  adminPhone       String?       // numéro de téléphone admin
  teachersCount    Int
  status           RequestStatus @default(PENDING)
  slug             String?       // généré à l'approbation
  rejectionReason  String?
  createdAt        DateTime      @default(now())
  processedAt      DateTime?

  @@index([status])
  @@map("school_requests")
}

// ==================== FEEDBACK / BUG REPORTS ====================

enum FeedbackType {
  BUG
  SUGGESTION
  FEEDBACK
  OTHER
}

enum FeedbackStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum FeedbackPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Feedback {
  id          String           @id @default(uuid())
  schoolId    String
  userId      String
  type        FeedbackType     @default(BUG)
  category    String           @default("GENERAL") // UI, PERFORMANCE, FEATURE, BUG, OTHER
  title       String
  message     String           @db.Text
  screenshot  String?          // URL de la photo/screenshot
  status      FeedbackStatus   @default(PENDING)
  priority    FeedbackPriority @default(LOW)
  adminNote   String?          @db.Text
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([status, priority])
  @@index([createdAt])
  @@map("feedbacks")
}