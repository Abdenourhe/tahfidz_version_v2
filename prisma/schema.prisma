// schema.prisma — TAHFIDZ SaaS
// Architecture multi-tenant : Row-Level Isolation par schoolId
// CORRIGÉ : ENUMs remplacés par String pour éviter les problèmes de types PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ==================== ENUMS (natifs PostgreSQL — déjà existants) ====================

enum UserRole {
  SUPERADMIN
  ADMIN
  TEACHER
  PARENT
  STUDENT
}

enum SchoolPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum Gender {
  MALE
  FEMALE
}

enum MemorizationStatus {
  NOT_STARTED
  ASSIGNED
  IN_PROGRESS
  UNDER_REVIEW
  READY_FOR_RECITATION
  PENDING_TEACHER_APPROVAL
  MEMORIZED
  NEEDS_REVISION
}

enum ProgressQuality {
  EXCELLENT
  GOOD
  NEEDS_WORK
  POOR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AnnouncementType {
  GENERAL
  EVENT
  ACHIEVEMENT
  URGENT
}

enum BadgeRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum EvaluationDecision {
  APPROVED
  NEEDS_REVISION
  REJECTED
}

// ==================== ÉCOLE (tenant racine) ====================

model School {
  id                String     @id @default(uuid())
  name              String
  nameAr            String?
  slug              String     @unique
  plan              SchoolPlan @default(FREE)
  isActive          Boolean    @default(true)
  settings          Json       @default("{}")
  address           String?
  city              String?
  country           String?    @default("DZ")
  phone             String?
  logo              String?
  directorSignature String?
  teacherSignature  String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  users                User[]
  groups               Group[]
  halaqaSessions       HalaqaSession[]       @relation("SchoolHalaqa")
  announcements        Announcement[]
  notifications        Notification[]
  exams                Exam[]
  directMessages       DirectMessage[]
  badges               Badge[]
  auditLogs            AuditLog[]            @relation("SchoolAuditLogs")
  feedbacks            Feedback[]            @relation("SchoolFeedbacks")
  parentInvites        ParentInvite[]
  certificateTemplates CertificateTemplate[]
  libraryCategories    LibraryCategory[]
  libraryCollections   LibraryCollection[]
  libraryContents      LibraryContent[]

  @@index([slug])
  @@map("schools")
}

// ==================== UTILISATEURS ====================

model User {
  id            String    @id @default(uuid())
  schoolId      String
  email         String
  password      String
  fullName      String
  fullNameAr    String?
  role          UserRole
  phone         String?
  gender        Gender?
  avatar        String?
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  messageNotifications    Boolean @default(true)
  evaluationNotifications Boolean @default(true)
  attendanceNotifications Boolean @default(true)
  presenceNotifications   Boolean @default(true)
  soundEnabled            Boolean @default(true)
  notificationPrefs       Json    @default("{}")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  adminProfile   Admin?
  teacherProfile Teacher?
  parentProfile  Parent?
  studentProfile Student?

  teacherHalaqaSessions HalaqaSession[]    @relation("TeacherHalaqa")
  studentHalaqaEvals    HalaqaEvaluation[] @relation("StudentHalaqaEval")

  notifications     Notification[]
  sentMessages      DirectMessage[]    @relation("SentMessages")
  receivedMessages  DirectMessage[]    @relation("ReceivedMessages")
  messageReactions  MessageReaction[]
  sessions          Session[]
  announcements     Announcement[]
  auditLogs         AuditLog[]         @relation("UserAuditLogs")
  feedbacks         Feedback[]         @relation("UserFeedbacks")
  parentAttendances ParentAttendance[]
  dailyLogsCreated  DailyProgressLog[]
  dailyLogComments  DailyLogComment[]
  contentProgress   UserContentProgress[]
  bookmarks         UserBookmark[]

  @@unique([schoolId, email])
  @@index([schoolId, role])
  @@index([schoolId, email])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Admin {
  id          String @id @default(uuid())
  userId      String @unique
  permissions Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Teacher {
  id             String  @id @default(uuid())
  userId         String  @unique
  bio            String?
  specialization String?
  maxStudents    Int     @default(20)
  isActive       Boolean @default(true)

  user                    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups                  Group[]
  evaluations             Evaluation[]
  students                Student[]
  exams                   Exam[]
  memorizationAssignments MemorizationProgress[]

  @@map("teachers")
}

model Parent {
  id              String  @id @default(uuid())
  userId          String  @unique
  nationality     String?
  spokenLanguages String?

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  childrenLinks ParentStudentLink[]

  @@map("parents")
}

model Student {
  id             String    @id @default(uuid())
  userId         String    @unique
  studentCode    String    @unique
  dateOfBirth    DateTime?
  enrollmentDate DateTime  @default(now())
  emergencyPhone String?
  // ← AJOUTÉ : Adresse complète
  address        String?
  city           String?
  postalCode     String?
  // ← AJOUTÉ : Notes médicales
  medicalNotes   String?   @db.Text
  groupId        String?
  teacherId      String?

  currentSurahId   Int?
  currentSurahNote String?
  nationality      String?
  spokenLanguages  String?
  totalStars       Int       @default(0)
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  status           String    @default("active")

  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group                Group?                 @relation(fields: [groupId], references: [id])
  teacher              Teacher?               @relation(fields: [teacherId], references: [id])
  parentLinks          ParentStudentLink[]
  parentInvites        ParentInvite[]
  memorizationProgress MemorizationProgress[]
  memorizedSurahs      MemorizedSurah[]
  attendances          Attendance[]
  parentAttendances    ParentAttendance[]
  studentBadges        StudentBadge[]
  starsLogs            StarsLog[]
  evaluations          Evaluation[]
  dailyLogs            DailyProgressLog[]
  stats                StudentStats?
  libraryEnrollments   LibraryCollectionEnrollment[]

  @@index([groupId])
  @@index([teacherId])
  @@map("students")
}

model ParentStudentLink {
  id         String   @id @default(uuid())
  parentId   String
  studentId  String
  relation   String
  accessCode String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_student_links")
}

// ==================== INVITATIONS PARENT ====================

model ParentInvite {
  id        String    @id @default(cuid())
  code      String    @unique
  studentId String    @unique
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([code])
  @@index([studentId])
  @@index([schoolId])
  @@map("parent_invites")
}

// ==================== GROUPES ====================

model Group {
  id          String   @id @default(uuid())
  schoolId    String
  name        String
  nameAr      String?
  teacherId   String
  level       String
  schedule    Json?
  maxCapacity Int      @default(15)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  school         School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher        Teacher             @relation(fields: [teacherId], references: [id])
  students       Student[]
  exams          Exam[]
  announcements  GroupAnnouncement[]
  attendances    Attendance[]
  halaqaSessions HalaqaSession[]     @relation("GroupHalaqa")
  libraryCollections LibraryCollection[]

  @@index([schoolId])
  @@index([teacherId])
  @@map("groups")
}

// ==================== SOURATES ====================

model Surah {
  id              Int    @id
  nameAr          String
  nameFr          String
  nameEn          String
  verseCount      Int
  juzNumber       Int
  revelationType  String
  difficultyLevel Int    @default(3)
  orderInMushaf   Int

  progressRecords  MemorizationProgress[]
  memorizedRecords MemorizedSurah[]

  @@map("surahs")
}

// ==================== MÉMORISATION ====================

model MemorizationProgress {
  id                   String             @id @default(uuid())
  studentId            String
  teacherId            String?
  surahId              Int
  startVerse           Int                @default(1)
  endVerse             Int
  versesFrom           Int?
  versesTo             Int?
  targetDate           DateTime?
  dueDate              DateTime?
  status               MemorizationStatus @default(NOT_STARTED)
  currentVerse         Int                @default(1)
  completionPercentage Float              @default(0)
  revisionCount        Int                @default(0)
  lastRevisedAt        DateTime?
  notes                String?            @db.Text
  startedAt            DateTime           @default(now())
  completedAt          DateTime?
  updatedAt            DateTime           @updatedAt

  student       Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher       Teacher?        @relation(fields: [teacherId], references: [id])
  surah         Surah           @relation(fields: [surahId], references: [id])
  evaluation    Evaluation?
  statusHistory StatusHistory[]

  @@unique([studentId, surahId, startVerse, endVerse])
  @@index([studentId, status])
  @@index([teacherId])
  @@map("memorization_progress")
}

model StatusHistory {
  id              String             @id @default(uuid())
  progressId      String
  oldStatus       MemorizationStatus
  newStatus       MemorizationStatus
  changedBy       String
  versesMemorized Int?
  quality         ProgressQuality?
  changedAt       DateTime           @default(now())
  note            String?

  progress MemorizationProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@map("status_history")
}

model MemorizedSurah {
  id              String   @id @default(uuid())
  studentId       String
  surahId         Int
  progressId      String   @unique
  completionDate  DateTime @default(now())
  versesMemorized Int
  finalScore      Int?
  teacherNotes    String?
  starsEarned     Int      @default(0)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  surah   Surah   @relation(fields: [surahId], references: [id])

  @@map("memorized_surahs")
}

// ==================== CARNET QUOTIDIEN ====================

model DailyProgressLog {
  id          String   @id @default(uuid())
  studentId   String
  date        DateTime @db.Date
  createdById String

  // Hifz
  hifzFromSurahId Int?
  hifzFromVerse   Int?
  hifzToSurahId   Int?
  hifzToVerse     Int?
  hifzNote        String? @db.Text

  // Muraja'a
  murajaFromSurahId Int?
  murajaFromVerse   Int?
  murajaToSurahId   Int?
  murajaToVerse     Int?
  murajaNote        String? @db.Text

  // Talqin
  talqinFromSurahId Int?
  talqinFromVerse   Int?
  talqinToSurahId   Int?
  talqinToVerse     Int?
  talqinNote        String? @db.Text

  // Cours scientifique
  courseBook     String?
  courseFromPage Int?
  courseToPage   Int?
  courseNote     String? @db.Text

  // Assiduité / Observations
  attendanceStatus   String?
  teacherObservation String? @db.Text
  parentObservation  String? @db.Text

  // Global
  globalScore Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdBy User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  comments  DailyLogComment[]

  @@unique([studentId, date])
  @@index([studentId, date])
  @@map("daily_progress_logs")
}

model DailyLogComment {
  id         String   @id @default(uuid())
  dailyLogId String
  section    String // HIFZ, MURAJA, TALQIN, COURSE, ATTENDANCE, GENERAL
  userId     String
  message    String   @db.Text
  createdAt  DateTime @default(now())

  dailyLog DailyProgressLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dailyLogId, section])
  @@map("daily_log_comments")
}

// ==================== ÉVALUATIONS ====================

model Evaluation {
  id                  String             @id @default(uuid())
  progressId          String             @unique
  studentId           String
  teacherId           String
  evaluatedAt         DateTime           @default(now())
  evaluationType      String
  memorizationScore   Int
  tajwid              Int                @default(0)
  makhraj             Int                @default(0)
  waqf                Int                @default(0)
  tarteel             Int                @default(0)
  tajweedScore        Int
  fluencyScore        Int
  makharijScore       Int?
  tafsirUnderstanding Int?
  finalScore          Int
  teacherNotes        String?            @db.Text
  strengths           String[]
  improvements        String[]
  revisionRequired    Boolean            @default(false)
  decision            EvaluationDecision

  progress MemorizationProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  student  Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher  Teacher              @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([teacherId])
  @@map("evaluations")
}

// ==================== PRÉSENCES ====================

model Attendance {
  id           String           @id @default(uuid())
  studentId    String
  groupId      String?
  date         DateTime
  status       AttendanceStatus
  checkInTime  DateTime?
  checkOutTime DateTime?
  notes        String?
  recordedBy   String
  createdAt    DateTime         @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group   Group?  @relation(fields: [groupId], references: [id])

  @@unique([studentId, date])
  @@index([date])
  @@index([groupId])
  @@map("attendances")
}

model ParentAttendance {
  id          String           @id @default(uuid())
  studentId   String
  parentId    String
  date        DateTime         @db.Date
  status      AttendanceStatus
  reason      String?
  validatedBy String?
  validatedAt DateTime?
  createdAt   DateTime         @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent  User    @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([studentId, date])
  @@index([parentId, date])
  @@index([status, validatedBy])
  @@map("parent_attendances")
}

// ==================== BADGES & RÉCOMPENSES ====================

model Badge {
  id            String      @id @default(uuid())
  schoolId      String?
  name          String
  nameAr        String
  description   String
  descriptionAr String
  icon          String
  color         String
  criteriaType  String
  criteriaValue Int
  rarity        BadgeRarity @default(COMMON)

  school        School?        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentBadges StudentBadge[]

  @@index([schoolId])
  @@map("badges")
}

model StudentBadge {
  id          String   @id @default(uuid())
  studentId   String
  badgeId     String
  earnedAt    DateTime @default(now())
  earnedValue Int

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  badge   Badge   @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([studentId, badgeId])
  @@map("student_badges")
}

model StarsLog {
  id           String   @id @default(uuid())
  studentId    String
  amount       Int
  balanceAfter Int
  sourceType   String
  sourceId     String?
  reason       String
  awardedBy    String?
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("stars_logs")
}

// ==================== ANNONCES ====================

model Announcement {
  id          String           @id @default(uuid())
  schoolId    String
  title       String
  titleAr     String?
  content     String           @db.Text
  contentAr   String?          @db.Text
  type        AnnouncementType @default(GENERAL)
  targetRoles UserRole[]
  isPinned    Boolean          @default(false)
  isPublished Boolean          @default(true)
  publishedAt DateTime         @default(now())
  expiresAt   DateTime?
  createdBy   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  school       School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  author       User                @relation(fields: [createdBy], references: [id])
  targetGroups GroupAnnouncement[]

  @@index([schoolId, isPublished, publishedAt])
  @@map("announcements")
}

model GroupAnnouncement {
  id             String @id @default(uuid())
  announcementId String
  groupId        String

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([announcementId, groupId])
  @@map("group_announcements")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String    @id @default(uuid())
  schoolId  String
  userId    String
  type      String
  title     String
  titleAr   String?
  message   String
  messageAr String?
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, userId, isRead])
  @@map("notifications")
}

// ==================== STATISTIQUES ====================

model StudentStats {
  id                   String    @id @default(uuid())
  studentId            String    @unique
  totalSurahsMemorized Int       @default(0)
  totalVersesMemorized Int       @default(0)
  totalEvaluationScore Int       @default(0)
  evaluationCount      Int       @default(0)
  averageScore         Float     @default(0)
  attendanceRate       Float     @default(0)
  currentStreakStart   DateTime?
  longestStreakStart   DateTime?
  longestStreakEnd     DateTime?
  lastCalculatedAt     DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_stats")
}

// ==================== ERROR LOGS ====================

model ErrorLog {
  id        String   @id @default(uuid())
  message   String
  stack     String?
  severity  String   @default("ERROR")
  source    String   @default("api")
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([severity])
  @@map("error_logs")
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id       String @id @default(uuid())
  schoolId String
  userId   String

  action     String
  actorId    String
  actorRole  String
  actorEmail String?
  actorName  String?

  entityType String? // ← AJOUTÉ (pour compatibilité avec l'ancienne base)
  entityId   String? // ← AJOUTÉ (pour compatibilité avec l'ancienne base)

  targetType String?
  targetId   String?
  targetName String?

  details   String?
  severity  String  @default("INFO")
  oldValues Json?
  newValues Json?

  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  school School @relation("SchoolAuditLogs", fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, userId])
  @@index([schoolId, action])
  @@index([action])
  @@index([severity])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==================== BROADCAST ====================

model Broadcast {
  id         String   @id @default(uuid())
  schoolId   String?
  title      String
  message    String   @db.Text
  target     String   @default("all")
  sentBy     String
  sentAt     DateTime @default(now())
  readCount  Int      @default(0)
  totalCount Int      @default(0)

  @@index([schoolId])
  @@index([sentAt])
  @@map("broadcasts")
}

// ==================== EXAMENS ====================

model Exam {
  id          String   @id @default(uuid())
  schoolId    String
  title       String
  titleAr     String?
  description String?  @db.Text
  groupId     String
  teacherId   String
  examDate    DateTime
  duration    Int      @default(60)
  surahIds    Int[]
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@index([schoolId])
  @@index([groupId])
  @@index([teacherId])
  @@map("exams")
}

// ==================== MESSAGES DIRECTS ====================

model DirectMessage {
  id         String    @id @default(uuid())
  schoolId   String
  fromUserId String
  toUserId   String
  subject    String
  body       String    @db.Text
  isRead     Boolean   @default(false)
  sentAt     DateTime  @default(now())
  deletedAt  DateTime?

  replyToId String?
  replyTo   DirectMessage?  @relation("MessageThread", fields: [replyToId], references: [id])
  replies   DirectMessage[] @relation("MessageThread")

  reactions MessageReaction[]

  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fromUser User   @relation("SentMessages", fields: [fromUserId], references: [id])
  toUser   User   @relation("ReceivedMessages", fields: [toUserId], references: [id])

  @@index([schoolId, toUserId, isRead])
  @@index([schoolId, sentAt])
  @@map("direct_messages")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

// ==================== DEMANDES D'INSCRIPTION ====================

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model SchoolRequest {
  id               String        @id @default(uuid())
  schoolName       String
  city             String?
  country          String        @default("DZ")
  plan             SchoolPlan    @default(FREE)
  address          String?
  adminEmail       String
  adminPassword    String
  adminName        String
  classCount       Int
  studentsPerClass Int
  adminPhone       String?
  teachersCount    Int
  logo             String?
  status           RequestStatus @default(PENDING)
  slug             String?
  rejectionReason  String?
  createdAt        DateTime      @default(now())
  processedAt      DateTime?

  @@index([status])
  @@map("school_requests")
}

model SchoolUpdateRequest {
  id              String        @id @default(uuid())
  schoolId        String
  requestedBy     String
  name            String?
  nameAr          String?
  address         String?
  city            String?
  country         String?
  phone           String?
  status          RequestStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime      @default(now())
  processedAt     DateTime?

  @@index([schoolId, status])
  @@index([status])
  @@map("school_update_requests")
}

// ==================== FEEDBACK / BUG REPORTS ====================
// CORRIGÉ : ENUMs remplacés par String pour éviter les problèmes de types PostgreSQL

model Feedback {
  id         String    @id @default(uuid())
  schoolId   String
  userId     String
  type       String    @default("BUG") // BUG, SUGGESTION, FEEDBACK, OTHER
  category   String    @default("GENERAL") // UI, PERFORMANCE, FEATURE, BUG, OTHER
  title      String
  message    String    @db.Text
  screenshot String?
  status     String    @default("PENDING") // PENDING, IN_PROGRESS, RESOLVED, CLOSED
  priority   String    @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  adminNote  String?   @db.Text
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  school School @relation("SchoolFeedbacks", fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation("UserFeedbacks", fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([status, priority])
  @@index([createdAt])
  @@map("feedbacks")
}

// ==================== HALAQA ONLINE (BigBlueButton) ====================

enum HalaqaType {
  INDIVIDUAL
  COLLECTIVE
}

enum HalaqaStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum HalaqaMode {
  AUDIO_ONLY
  VIDEO
  SCREEN_SHARE
}

model HalaqaSession {
  id          String  @id @default(cuid())
  meetingID   String  @unique
  meetingName String
  roomUrl     String // URL join prof (MODERATOR)
  attendeeUrl String? // URL join élève (VIEWER)
  guestUrl    String? // URL join parent (OBSERVER)

  schoolId String
  school   School @relation("SchoolHalaqa", fields: [schoolId], references: [id], onDelete: Cascade)

  teacherId  String
  teacher    User     @relation("TeacherHalaqa", fields: [teacherId], references: [id], onDelete: Cascade)
  studentIds String[] // Array of student User IDs

  groupId String?
  group   Group?  @relation("GroupHalaqa", fields: [groupId], references: [id], onDelete: SetNull)

  type   HalaqaType
  status HalaqaStatus @default(SCHEDULED)
  mode   HalaqaMode   @default(AUDIO_ONLY)

  scheduledAt DateTime
  startedAt   DateTime?
  endedAt     DateTime?
  duration    Int? // minutes

  recordingUrl String?
  recordingId  String?

  sourah String?
  verses String?

  evaluations HalaqaEvaluation[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([schoolId])
  @@index([teacherId])
  @@index([groupId])
  @@index([status])
  @@index([scheduledAt])
  @@map("halaqa_sessions")
}

model HalaqaEvaluation {
  id        String        @id @default(cuid())
  sessionId String
  session   HalaqaSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId String
  student   User          @relation("StudentHalaqaEval", fields: [studentId], references: [id], onDelete: Cascade)

  sourah            String?
  verses            String?
  tajweedScore      Int?
  memorizationScore Int?
  fluencyScore      Int?
  notes             String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@map("halaqa_evaluations")
}

model CertificateTemplate {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String // Nom affiché, ex: "Mémorisation", "Assiduité"...
  nameAr    String?
  config    Json // Configuration complète du template
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("certificate_templates")
}

// ============================================
// BIBLIOTHÈQUE
// ============================================

enum ContentType {
  PDF
  VIDEO_SERIES
  VIDEO_SINGLE
  AUDIO
}

enum ContentVisibility {
  GLOBAL
  SCHOOL
  CLASS
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CollectionEnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

model LibraryCategory {
  id          String   @id @default(cuid())
  schoolId    String?  // NULL = catégorie globale (superadmin)
  name        String
  nameAr      String?
  nameEn      String?
  description String?
  icon        String?
  color       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents LibraryContent[]
  school   School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([sortOrder])
  @@map("library_categories")
}

model LibraryCollection {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  nameAr      String?
  nameEn      String?
  description String?
  coverImage  String?
  color       String?
  isActive    Boolean  @default(true)
  createdBy   String

  // Lien optionnel au Group existant
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id])

  // Collections autonomes (groupId = null)
  enrollments LibraryCollectionEnrollment[]
  contents    LibraryContent[]

  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
  @@index([groupId])
  @@map("library_collections")
}

model LibraryCollectionEnrollment {
  id            String                     @id @default(cuid())
  collectionId  String
  studentId     String
  enrolledAt    DateTime                   @default(now())
  status        CollectionEnrollmentStatus @default(ACTIVE)

  collection    LibraryCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  student       Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([collectionId, studentId])
  @@index([collectionId])
  @@index([studentId])
  @@map("library_collection_enrollments")
}

model LibraryContent {
  id            String   @id @default(cuid())
  schoolId      String?  // NULL = contenu GLOBAL

  // Hiérarchie
  visibility    ContentVisibility
  collectionId  String?  // NULL si GLOBAL ou contenu SCHOOL sans collection

  // Métadonnées
  type          ContentType
  status        ContentStatus @default(DRAFT)
  title         String
  titleAr       String?
  titleEn       String?
  description   String?  @db.Text
  descriptionAr String?  @db.Text
  descriptionEn String?  @db.Text

  // Média
  thumbnail     String?
  coverImage    String?

  // PDF
  pdfUrl        String?
  pdfPages      Int?

  // Vidéo / audio
  videoUrl      String?
  videoSource   String?  // youtube, vimeo, local
  duration      Int?

  // Meta
  categoryId    String
  author        String?
  language      String?
  level         String?
  tags          String[]

  // Audit
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  school        School?            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  category      LibraryCategory    @relation(fields: [categoryId], references: [id])
  collection    LibraryCollection? @relation(fields: [collectionId], references: [id])
  episodes      LibraryEpisode[]
  progress      UserContentProgress[]
  bookmarks     UserBookmark[]

  @@index([schoolId])
  @@index([visibility, collectionId])
  @@index([categoryId])
  @@index([type, status])
  @@map("library_contents")
}

model LibraryEpisode {
  id            String   @id @default(cuid())
  contentId     String
  title         String
  titleAr       String?
  titleEn       String?
  description   String?  @db.Text
  videoUrl      String
  duration      Int?
  episodeOrder  Int      @default(0)
  thumbnail     String?

  content       LibraryContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([contentId])
  @@index([episodeOrder])
  @@map("library_episodes")
}

model UserContentProgress {
  id            String   @id @default(cuid())
  userId        String
  contentId     String
  progress      Float    @default(0)
  lastPosition  Int?
  isCompleted   Boolean  @default(false)
  completedAt   DateTime?
  updatedAt     DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       LibraryContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
  @@index([contentId])
  @@map("user_content_progress")
}

model UserBookmark {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  note      String?
  createdAt DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   LibraryContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
  @@map("user_bookmarks")
}

model UploadedFile {
  id          String   @id @default(cuid())
  schoolId    String?  // NULL = fichier global (superadmin)
  hash        String   // SHA-256 du fichier
  key         String   @unique // Clé R2 (ex: schools/.../file.pdf)
  fileName    String
  contentType String
  size        Int
  createdAt   DateTime @default(now())

  @@index([hash])
  @@index([schoolId, hash])
  @@map("uploaded_files")
}
